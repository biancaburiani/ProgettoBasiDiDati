CREATE DATABASE IF NOT EXISTS nome_database;
USE esg_balance;

CREATE TABLE utente (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50),
    password VARCHAR(255),
    cf VARCHAR(16),
    data_nascita DATE,
    luogo_nascita VARCHAR(100)
);

CREATE TABLE email (
    id INT AUTO_INCREMENT PRIMARY KEY,
    indirizzo VARCHAR(100),
    utente_id INT NOT NULL,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE amministratore (
    utente_id INT PRIMARY KEY,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE revisore_esg (
    id INT AUTO_INCREMENT PRIMARY KEY,
    indice_affidabilita DECIMAL(5,2),
    n_revisioni_effettuate INT
);

CREATE TABLE responsabile_aziendale (
    utente_id INT PRIMARY KEY,
    curriculum TEXT,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE competenza (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100)
);

CREATE TABLE possiede_competenza (
    revisore_id INT,
    competenza_id INT,
    livello VARCHAR(50),
    PRIMARY KEY (revisore_id, competenza_id),
    FOREIGN KEY (revisore_id) REFERENCES revisore_esg(id),
    FOREIGN KEY (competenza_id) REFERENCES competenza(id)
);

CREATE TABLE azienda (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    regione_sociale VARCHAR(100),
    settore VARCHAR(100),
    nr_bilanci INT,
    luogo VARCHAR(100),
    piva VARCHAR(20),
    num_dipendenti INT
);

CREATE TABLE bilancio (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data_creazione DATE,
    stato VARCHAR(50),
    azienda_id INT NOT NULL,
    FOREIGN KEY (azienda_id) REFERENCES azienda(id)
);

