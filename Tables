CREATE DATABASE IF NOT EXISTS esg_balance;
USE esg_balance;

CREATE TABLE utente (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    cf VARCHAR(16) UNIQUE NOT NULL,
    data_nascita DATE,
    luogo_nascita VARCHAR(100)
);

CREATE TABLE email (
    id INT AUTO_INCREMENT PRIMARY KEY,
    indirizzo VARCHAR(100),
    utente_id INT NOT NULL,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE amministratore (
    utente_id INT PRIMARY KEY,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE revisore_esg (
    utente_id INT PRIMARY KEY,
    indice_affidabilita DECIMAL(5,2),
    n_revisioni_effettuate INT,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE responsabile_aziendale (
    utente_id INT PRIMARY KEY,
    curriculum TEXT,
    FOREIGN KEY (utente_id) REFERENCES utente(id)
);

CREATE TABLE competenza (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100)
);

CREATE TABLE possiede_competenza (
    revisore_id INT,
    competenza_id INT,
    livello VARCHAR(50),
    PRIMARY KEY (revisore_id, competenza_id),
    FOREIGN KEY (revisore_id) REFERENCES revisore_esg(id),
    FOREIGN KEY (competenza_id) REFERENCES competenza(id)
);

CREATE TABLE azienda (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    ragione_sociale VARCHAR(100) UNIQUE NOT NULL, -- La specifica dice univoca
    settore VARCHAR(100),
    partita_iva VARCHAR(20) UNIQUE,
    num_dipendenti INT,
    logo_path VARCHAR(255),
    nr_bilanci INT DEFAULT 0, -- Ridondanza richiesta
    id_responsabile INT NOT NULL,
    FOREIGN KEY (id_responsabile) REFERENCES responsabile_aziendale(utente_id)
);

CREATE TABLE bilancio (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data_creazione DATE,
    stato VARCHAR(50),
    azienda_id INT NOT NULL,
    FOREIGN KEY (azienda_id) REFERENCES azienda(id)
);

CREATE TABLE voce_template (
    id_voce_template INT AUTO_INCREMENT PRIMARY KEY,
    nome_voce VARCHAR(100) NOT NULL UNIQUE,
    descrizione VARCHAR(1000)
);

CREATE TABLE riga_bilancio (
    id_riga_bilancio INT AUTO_INCREMENT PRIMARY KEY,
    id_bilancio INT NOT NULL,
    id_voce_template INT NOT NULL,
    valore_numerico DECIMAL(15,2) NOT NULL,
    FOREIGN KEY (id_bilancio) REFERENCES bilancio(id),
    FOREIGN KEY (id_voce_template) REFERENCES voce_template(id_voce_template),
    UNIQUE(id_bilancio, id_voce_template) -- Impedisce di avere due volte la stessa voce nello stesso bilancio
);

CREATE TABLE indicatore_esg (
    id_indicatore INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL UNIQUE,
    immagine VARCHAR(255),
    rilevanza INT NOT NULL,
    CHECK (rilevanza BETWEEN 0 AND 10)
);

CREATE TABLE indicatore_ambientale (
    id_indicatore INT PRIMARY KEY,
    codice_normativa_rilevamento VARCHAR(20) NOT NULL,
    FOREIGN KEY (id_indicatore) REFERENCES indicatore_esg(id_indicatore)
    ON DELETE CASCADE
    ON UPDATE CASCADE
);

CREATE TABLE indicatore_sociale (
    id_indicatore INT PRIMARY KEY,
    ambito_sociale VARCHAR(100) NOT NULL,
    frequenza_di_rilevazione VARCHAR(100) NOT NULL,
    FOREIGN KEY (id_indicatore) REFERENCES indicatore_esg(id_indicatore)
    ON DELETE CASCADE
    ON UPDATE CASCADE
);

CREATE TABLE misura_con (
    id_riga_bilancio INT NOT NULL,
    id_indicatore_esg INT NOT NULL,
    valore_indicatore DECIMAL(15,2),
    fonte VARCHAR(255),
    data_rilevazione DATE,
    PRIMARY KEY (id_riga_bilancio, id_indicatore_esg),
    FOREIGN KEY (id_riga_bilancio) REFERENCES riga_bilancio(id_riga_bilancio),
    FOREIGN KEY (id_indicatore_esg) REFERENCES indicatore_esg(id_indicatore)
);

CREATE TABLE valuta (
    id_revisore INT NOT NULL,
    id_bilancio INT NOT NULL,
    PRIMARY KEY (id_revisore, id_bilancio),
    FOREIGN KEY (id_revisore) REFERENCES revisore_esg(id_utente)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (id_bilancio) REFERENCES bilancio(id_bilancio)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE nota (
    id_nota INT AUTO_INCREMENT PRIMARY KEY,
    data DATE NOT NULL,
    testo TEXT NOT NULL,
    id_revisore INT NOT NULL,
    id_riga_bilancio INT NOT NULL,
    FOREIGN KEY (id_revisore) REFERENCES revisore_esg(id_utente)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (id_riga_bilancio) REFERENCES riga_bilancio(id_riga_bilancio)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);

CREATE TABLE giudizio (
    id INT AUTO_INCREMENT PRIMARY KEY,
    esito ENUM('approvazione', 'approvazione_con_rilievi', 'respingimento') NOT NULL,
    data DATE NOT NULL,
    rilievi TEXT,
    id_revisore_esg INT NOT NULL,
    id_bilancio INT NOT NULL,
    FOREIGN KEY (id_revisore) REFERENCES revisore_esg(id_utente)
        ON DELETE CASCADE
        ON UPDATE CASCADE,
    FOREIGN KEY (id_bilancio) REFERENCES bilancio(id_bilancio)
        ON DELETE CASCADE
        ON UPDATE CASCADE
);




