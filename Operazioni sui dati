-- AGGIUNGI EMAIL STORED PROCEDURE --
DELIMITER //

----------------------------------------------------------------------------------- STORED PROCEDURE aggiungi_email ---------------------------------------------------------------------------------------------------
DROP PROCEDURE IF EXISTS aggiungi_email;

DELIMITER //

CREATE PROCEDURE aggiungi_email(
    IN p_utente_id INT,
    IN p_nuovo_indirizzo VARCHAR(100)
)

BEGIN
    -- 1. Verifica se l'indirizzo email è già registrato da chiunque
    IF EXISTS (SELECT 1 FROM email WHERE indirizzo = p_nuovo_indirizzo) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Errore: Questo indirizzo email è già associato a un account.';
    
    -- 2. Verifica se l'utente esiste
    ELSEIF NOT EXISTS (SELECT 1 FROM utente WHERE id = p_utente_id) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Errore: Utente non trovato.';
        
    ELSE
        -- 3. Inserimento sicuro
        INSERT INTO email (indirizzo, utente_id)
        VALUES (p_nuovo_indirizzo, p_utente_id);
    END IF;
END //

DELIMITER ;

------------------------------------------------------------------------------ stored procedure inserimento_indicatore_esg ----------------------------------------------------------------------------------------------------------------------
DROP PROCEDURE IF EXISTS inserisci_indicatore_esg;
DELIMITER //

CREATE PROCEDURE inserisci_indicatore_esg(
    IN p_admin_id INT,
    IN p_nome VARCHAR(100),
    IN p_immagine VARCHAR(255),
    IN p_rilevanza INT,
    IN p_tipo VARCHAR(20),
    IN p_codice_normativa VARCHAR(50),
    IN p_ambito_sociale VARCHAR(100),
    IN p_frequenza VARCHAR(50)
)
BEGIN
    DECLARE v_indicatore_id INT;

    IF NOT EXISTS (
        SELECT 1
        FROM amministratore
        WHERE utente_id = p_admin_id
    ) THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Errore: Solo gli amministratori possono eseguire questa operazione.';
    END IF;

    IF p_tipo NOT IN ('generico', 'ambientale', 'sociale') THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Errore: tipo indicatore non valido.';
    END IF;

    IF p_rilevanza NOT BETWEEN 0 AND 10 THEN
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Errore: rilevanza non valida.';
    END IF;

    INSERT INTO indicatore_esg (nome, immagine, rilevanza)
    VALUES (p_nome, p_immagine, p_rilevanza);

    SET v_indicatore_id = LAST_INSERT_ID();

    IF p_tipo = 'ambientale' THEN
        IF p_codice_normativa IS NULL OR TRIM(p_codice_normativa) = '' THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Errore: codice normativa obbligatorio per indicatore ambientale.';
        END IF;

        INSERT INTO indicatore_ambientale (id_indicatore, codice_normativa)
        VALUES (v_indicatore_id, p_codice_normativa);

    ELSEIF p_tipo = 'sociale' THEN
        IF p_ambito_sociale IS NULL OR TRIM(p_ambito_sociale) = ''
           OR p_frequenza IS NULL OR TRIM(p_frequenza) = '' THEN
            SIGNAL SQLSTATE '45000'
            SET MESSAGE_TEXT = 'Errore: ambito sociale e frequenza obbligatori per indicatore sociale.';
        END IF;

        INSERT INTO indicatore_sociale (id_indicatore, ambito_sociale, frequenza_rilevazione)
        VALUES (v_indicatore_id, p_ambito_sociale, p_frequenza);
    END IF;
END //

DELIMITER ;
